# Streamlit auth (OIDC)
[auth]
redirect_uri = "https://YOUR-APP.streamlit.app/oauth2callback"
cookie_secret = "replace-with-long-random-secret"

[auth.microsoft]
client_id = "replace-with-entra-client-id"
client_secret = "replace-with-entra-client-secret"
server_metadata_url = "https://login.microsoftonline.com/replace-with-tenant-id/v2.0/.well-known/openid-configuration"

# App/backendless mode
STREAMLIT_CLOUD_TEST_MODE = "true"
CLOUD_TEST_ALLOW_LOCAL_LOGIN = "false"
CLOUD_TEST_ALLOW_SQLITE_FALLBACK = "false"
ENABLE_DEVOPS_IN_UI = "false"
DATABASE_URL = "postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"
SQLITE_VEC_ENABLED = "true"
SQLITE_VEC_DIMENSIONS = "1536"
SQLITE_VEC_EMBEDDING_PROVIDER = "openai"
SQLITE_VEC_EMBEDDING_MODEL = "text-embedding-3-small"
STORAGE_DIR = "Cloud_test/storage"
ATTACHMENT_STORAGE_BACKEND = "filesystem"

# OpenAI
OPENAI_API_KEY = "sk-..."
OPENAI_MODEL = "gpt-4o-mini"
OPENAI_EMBEDDING_MODEL = "text-embedding-3-small"
AI_PROVIDER = "openai"
AI_MODEL = "gpt-4o-mini"
EMBEDDING_PROVIDER = "openai"
EMBEDDING_MODEL = "text-embedding-3-small"

# Optional role mapping for Entra users (comma-separated)
ENTRA_ADMIN_EMAILS = "admin1@company.com,admin2@company.com"
ENTRA_ASSIGNEE_EMAILS = "user1@company.com,user2@company.com"

# Optional local fallback-login (only if CLOUD_TEST_ALLOW_LOCAL_LOGIN = "true")
DEFAULT_ADMIN_EMAIL = "admin@example.com"
DEFAULT_ADMIN_PASSWORD = "replace-with-strong-password"
